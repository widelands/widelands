#: ../../../../data/tribes/initialization/amazons/units.lua:1040
#: ../../../../data/tribes/initialization/amazons/units.lua:1068
#: ../../../../data/tribes/initialization/amazons/units.lua:1096
#: ../../../../data/tribes/initialization/amazons/units.lua:1124
msgid "This rubber tree is fully grown. Lianas can be gathered from it."
msgstr "Šis guminis medis yra visiškai užaugintas. Iš jo galima surinkti lianus."

#. TRANSLATORS: Helptext for an Amazon immovable: Rubber Tree Old
#: ../../../../data/tribes/initialization/amazons/units.lua:1047
#: ../../../../data/tribes/initialization/amazons/units.lua:1075
