#: ../../../../data/tribes/initialization/amazons/units.lua:816
#: ../../../../data/tribes/initialization/amazons/units.lua:844
#: ../../../../data/tribes/initialization/amazons/units.lua:872
#: ../../../../data/tribes/initialization/amazons/units.lua:900
msgid "This balsa tree is fully grown. Lianas can be gathered from it."
msgstr "Šis balsa medis yra visiškai užaugintas. Iš jo galima surinkti lianus."

#. TRANSLATORS: Helptext for an Amazon immovable: Balsa Tree Old
#: ../../../../data/tribes/initialization/amazons/units.lua:823
#: ../../../../data/tribes/initialization/amazons/units.lua:851
#: ../../../../data/tribes/initialization/amazons/units.lua:879
#: ../../../../data/tribes/initialization/amazons/units.lua:907
msgid ""
"This balsa tree is ready for harvesting balsa wood by a master woodcutter. "
"Other tribes can harvest it for normal logs."
msgstr "Šis balzos medis yra paruoštas balsos medienos derliui nuimti meistro medžio pjaustytojo. Kitos gentys gali nuimti derlių už normalius rąstus."

