#. TRANSLATORS: To be used in placeholders for switching texts according to
#. current leader
#: ../../../../data/campaigns/atl02.wmf/scripting/texts.lua:40
#: ../../../../data/campaigns/atl02.wmf/scripting/texts.lua:337
