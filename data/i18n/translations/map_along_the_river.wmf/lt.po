#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/functions.lua:60
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/functions.lua:62
msgid "Transport"
msgstr "Transportas"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/init.lua:211
msgid ""
"Four shovels for removing the swamps have been collected at the warehouse."
msgstr "Sandėlyje surinkti keturi kastuvai pelkėms sausinti."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/init.lua:211
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/init.lua:220
msgid "Shovels"
msgstr "Kastuvai"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/init.lua:220
msgid ""
"Four more shovels for removing the swamps have been collected at the "
"warehouse."
msgstr "Sandėlyje surinkti dar keturi kastuvai pelkėms sausinti."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:7
msgid "Defeat Törver"
msgstr "Nugalėkite Törverį"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:9
msgid "Defeat the Armies of Törver"
msgstr "Nugalėkite Törverio armijas"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:10
msgid ""
"Törver is the enemy in the North, who is fighting under the red banner."
msgstr "Törveris yra priešas Šiaurėje, kovojantis po raudona vėliava."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:16
msgid "Build a port"
msgstr "Pastatykite uostą"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:18
msgid "Build a Port in the North"
msgstr "Pastatykite uostą Šiaurėje"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:19
msgid ""
"We should build a port in Törver’s former land to be ready to send an "
"expedition as soon as we found out how to build ships."
msgstr ""
"Turėtume pastatyti uostą buvusioje Törverio žemėje, kad būtume pasirengę "
"išsiųsti ekspediciją, kai tik sužinosime, kaip statyti laivus."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:25
msgid "Conquer pirate sentry"
msgstr "Užimkite piratų sargybos postą"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:27
msgid "Conquer the Pirate Sentry"
msgstr "Užimkite piratų sargybos postą"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:28
msgid ""
"Conquer the pirate sentry near the brook to the East. Hopefully we will find"
" out what happened to the gold in this area."
msgstr ""
"Užimkite piratų sargybos postą prie upelio rytuose. Tikėkimės, "
"išsiaiškinsime, kas nutiko auksui šiose apylinkėse."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:34
msgid "Build warehouse"
msgstr "Pastatyti sandėlį"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:36
msgid "Build a Warehouse near the Pirate Sentry"
msgstr "Pastatykite sandėlį šalia piratų sargybos posto"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:37
msgid ""
"Build a warehouse close to the conquered pirate sentry near the brook. We "
"will need it as a basis for further exploration. Furthermore we could use it"
" to store some gold that we will mine from the surrounding hills."
msgstr ""
"Pastatykite sandėlį netoli užimto piratų sargybos posto prie upelio. Jo "
"prireiks kaip bazės tolesniems tyrinėjimams. Be to, galėsime ten saugoti "
"auksą, kurį kasime aplinkinėse kalvose."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:43
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:52
msgid "Bring shovels"
msgstr "Atneškite kastuvus"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:45
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:54
msgid "Bring Four Shovels to the new Warehouse"
msgstr "Pristatykite keturis kastuvus į naująjį sandėlį"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:46
msgid "They will be handed out to some volunteers for drying up the swamps."
msgstr "Jie bus išdalinti kai kuriems savanoriams, kad šie nusausintų pelkes."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:55
msgid ""
"They will be handed out to additional volunteers for drying up the swamps."
msgstr ""
"Jie bus išdalinti papildomiems savanoriams, kad šie nusausintų pelkes."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:61
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:93
msgid "Defeat the pirates"
msgstr "Nugalėkite piratus"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:63
msgid "Defeat the Pirates"
msgstr "Nugalėkite piratus"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:64
msgid ""
"Free our neighbourhood from the pirate menace. The pirates are fighting "
"under the grey banner."
msgstr ""
"Išlaisvinkite mūsų apylinkes nuo piratų grėsmės. Piratai kovoja po pilka "
"vėliava."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:70
msgid "Free our scout from the pirates"
msgstr "Išlaisvinkite mūsų žvalgą iš piratų"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:72
msgid "Conquer the Stronghold on the Island"
msgstr "Užimkite tvirtovę saloje"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:73
msgid "This is where the scout is held captive."
msgstr "Čia žvalgas laikomas nelaisvėje."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:79
msgid "Defeat Hjalmar"
msgstr "Nugalėkite Hjalmarą"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:81
msgid "Defeat the Armies of Hjalmar"
msgstr "Nugalėkite Hjalmaro armijas"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:82
msgid ""
"Hjalmar is the enemy north of the former pirates, who is fighting under the "
"green banner."
msgstr ""
"Hjalmaras yra priešas į šiaurę nuo buvusių piratų, kuris kovoja po žalia "
"vėliava."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:88
msgid "Defeat Runar"
msgstr "Nugalėkite Runarą"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:90
msgid "Defeat the Armies of Runar"
msgstr "Nugalėkite Runaro armijas"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/objectives.lua:91
msgid ""
"Runar is the enemy south-east of the former pirates, who is fighting under "
"the yellow banner."
msgstr ""
"Runaras yra priešas į pietryčius nuo buvusių piratų, kuris kovoja po geltona"
" vėliava."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:10
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:26
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:34
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:45
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:51
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:60
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:69
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:78
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:85
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:92
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:99
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:105
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:111
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:117
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:123
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:132
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:138
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:147
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:156
msgid "Your Advisor"
msgstr "Jūsų patarėjas"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:11
msgid "Along the River"
msgstr "Palei upę"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:12
msgid "Sire, let me inform you about the surrounding tribes."
msgstr "Valdove, leiskite man pranešti apie aplinkines gentis."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:14
msgid ""
"From the North we are endangered by a belligerent tribe, led by warlord "
"Törver, that is rapidly building up its armies. They may soon have become "
"too strong to be defeated."
msgstr ""
"Iš šiaurės mums gresia karinga gentis, vadovaujama karo vado Törverio, kuri "
"sparčiai telkia savo kariuomenę. Greitai jie gali tapti per stiprūs, kad "
"juos nugalėtume."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:16
msgid ""
"A large area to the north-east is agonized by a wild horde of unfettered "
"pirates, led by their insane Arvid. Their presence blocks our ways to other "
"tribes."
msgstr ""
"Didelę teritoriją į šiaurės rytus kankina laukinė nevaržomų piratų minia, "
"kuriai vadovauja jų beprotiškas Arvidas. Jų buvimas užkerta mums kelius pas "
"kitas gentis."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:18
msgid ""
"Over the river lies the prosperous land of the mysterious king Runar. We "
"have been in war with him before the pirates occupied the eastern area. His "
"strength is based on his vast industry and large armies."
msgstr ""
"Kitoje upės pusėje yra klestinti paslaptingojo karaliaus Runaro žemė. Mes su"
" juo kariavome dar prieš piratams užimant rytinę sritį. Jo stiprybė slypi "
"didžiulėje pramonėje ir gausioje kariuomenėje."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:20
msgid ""
"The area beyond the pirates belongs to a developed tribe led by their mighty"
" chieftain Hjalmar. They have had a long time of preparement to build up "
"their deterring armies."
msgstr ""
"Teritorija už piratų priklauso išsivysčiusiai genčiai, kuriai vadovauja jų "
"galingas vadas Hjalmaras. Jie turėjo daug laiko pasiruošti ir sutelkti savo "
"atgrasančią kariuomenę."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:22
msgid ""
"The situation looks quite perilous and my advice is that we direct our "
"efforts towards building up a strong army."
msgstr ""
"Situacija atrodo gana pavojinga, todėl patariu sutelkti pastangas į stiprios"
" kariuomenės kūrimą."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:27
msgid "Our northern enemy"
msgstr "Mūsų šiaurinis priešas"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:28
msgid ""
"Sire, although our soldiers would face any enemy without the slightest fear,"
" our rival in the North is still stronger than all our armies combined. We "
"should avoid a conflict until we are able to defeat them."
msgstr ""
"Valdove, nors mūsų kariai be menkiausios baimės stotų į kovą su bet kokiu "
"priešu, mūsų varžovas Šiaurėje vis dar yra stipresnis už visas mūsų pajėgas "
"kartu sudėjus. Turėtume vengti konflikto, kol būsime pajėgūs juos nugalėti."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:30
msgid ""
"Be patient and recognize that a strong army is indispensable in this "
"situation. Törver has a very bad reputation."
msgstr ""
"Būkite kantrūs ir pripažinkite, kad šioje situacijoje būtina stipri "
"kariuomenė. Törveris turi labai prastą reputaciją."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:35
msgid "Peril from the North"
msgstr "Pavojus iš Šiaurės"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:36
msgid ""
"Sire, we received an alarming message from one of our explorers. Törver is "
"expanding his front line and approaching our territory."
msgstr ""
"Valdove, gavome nerimą keliantį pranešimą iš vieno iš mūsų tyrinėtojų. "
"Törveris plečia savo fronto liniją ir artėja prie mūsų teritorijos."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:38
msgid ""
"We cannot avoid attacking their armies forever. If we manage to conquer our "
"northern enemy, we will enlarge our territory and find more resources to "
"strengthen our armies."
msgstr ""
"Negalime amžinai vengti pulti jų kariuomenės. Jei mums pavyks įveikti "
"šiaurinį priešą, išplėsime savo teritoriją ir rasime daugiau išteklių "
"pajėgoms stiprinti."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:40
msgid ""
"We can then also use their access to the lake in order to explore more land."
msgstr ""
"Tuomet galėsime pasinaudoti jų priėjimu prie ežero ir ištyrinėti daugiau "
"žemių."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:46
msgid "On the good way"
msgstr "Teisingu keliu"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:47
msgid ""
"Sire, the battle with Törver progresses gloriously and we have already "
"beaten the strongest part of his army. But this enemy will not be defeated "
"easily. In a desperate move Törver has called in a group of hardened "
"mercenaries."
msgstr ""
"Valdove, mūšis su Törveriu klostosi puikiai, mes jau įveikėme stipriausią jo"
" kariuomenės dalį. Tačiau šis priešas nebus lengvai nugalėtas. Iš nevilties "
"Törveris pasitelkė užkietėjusių samdinių grupę."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:52
msgid "The great lake"
msgstr "Didysis ežeras"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:53
msgid ""
"Sire, now that we have conquered the land of Törver, we can make use of "
"their excellent access to the adjacent great lake. A port in the North will "
"give us better opportunities to have contact with other tribes."
msgstr ""
"Valdove, dabar, kai užkariavome Törverio žemę, galime pasinaudoti puikiu jų "
"priėjimu prie gretimo Didžiojo ežero. Uostas Šiaurėje suteiks mums geresnes "
"galimybes užmegzti ryšius su kitomis gentimis."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:55
msgid ""
"In Törver’s headquarters we found papers describing the construction of "
"ships. Unfortunately, the texts are written in a language that is unknown to"
" us. Our wise men will try to translate these descriptions."
msgstr ""
"Törverio būstinėje radome dokumentų, kuriuose aprašoma laivų statyba. Deja, "
"tekstai parašyti mums nežinoma kalba. Mūsų išminčiai bandys išversti šiuos "
"aprašymus."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:61
msgid "Searching for gold"
msgstr "Aukso paieškos"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:62
msgid ""
"Sire, our men have located an isolated enemy pirate sentry. The abandoned "
"huts indicate that there is gold nearby."
msgstr ""
"Valdove, mūsų vyrai aptiko izoliuotą priešo piratų sargybos postą. Apleistos"
" trobelės rodo, kad netoliese yra aukso."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:64
msgid ""
"We should however be careful if we want to conquer the sentry. There can be "
"more enemy buildings that are still out of sight, and the pirates are known "
"to be very good fighters. It is best to establish a strong military presence"
" here before we proceed."
msgstr ""
"Tačiau turime būti atsargūs, jei norime užimti šį postą. Gali būti ir "
"daugiau priešo pastatų, kurių dar nematome, o piratai garsėja kaip labai "
"geri kovotojai. Prieš tęsiant geriausia čia sutelkti stiprias karines "
"pajėgas."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:70
msgid "Found a treasure"
msgstr "Rastas lobis"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:71
msgid ""
"Sire, we have found 25 units of gold ore inside the pirate sentry. They may "
"have been looted from the gold diggers’ huts nearby. This gold ore will be "
"transported to our headquarters."
msgstr ""
"Valdove, piratų sargybos poste radome 25 vienetus aukso rūdos. Jie galėjo "
"būti pagrobti iš netoliese esančių aukso ieškotojų namelių. Ši aukso rūda "
"bus gabenama į mūsų būstinę."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:73
msgid ""
"With our successful expansion into this area we should consider building a "
"warehouse to the direct southwest of the sentry in order to further explore "
"this area. There is a good building spot only three steps away from the "
"sentry."
msgstr ""
"Sėkmingai išplėtę šią sritį, turėtume apsvarstyti galimybę pastatyti sandėlį"
" tiesiai į pietvakarius nuo sargybos posto, kad galėtume toliau tyrinėti šią"
" sritį. Tik už trijų žingsnių nuo posto yra puiki vieta statyboms."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:79
#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:86
msgid "Removing the swamps"
msgstr "Pelkių sausinimas"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:80
msgid ""
"Sire, the wet season has created swamps along the brook to the East and we "
"are unable to pass through them. They have to be removed before we can "
"continue. If you bring enough shovels to the new warehouse then volunteers "
"will remove the swamps."
msgstr ""
"Valdove, per drėgnąjį sezoną palei upelį rytuose atsirado pelkių ir mes "
"negalime per jas praeiti. Jas būtina nusausinti, kad galėtume tęsti žygį. "
"Jei į naująjį sandėlį pristatysite pakankamai kastuvų, savanoriai nusausins "
"pelkes."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:87
msgid ""
"Sire, all shovels have been handed out, but if we continue at this pace we "
"will not have removed the swamps before the next wet season. If you bring "
"more shovels to the new warehouse then more volunteers will join in."
msgstr ""
"Valdove, visi kastuvai išdalinti, bet jei ir toliau dirbsime tokiu tempu, "
"nespėsime nusausinti pelkių iki kito drėgnojo sezono. Jei į naująjį sandėlį "
"pristatysite daugiau kastuvų, prisijungs daugiau savanorių."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:94
msgid ""
"Sire, now that we have access to the pirates’ hideout, we should conquer it "
"and finish them off. Maybe there are even more treasures hidden in their "
"territory."
msgstr ""
"Valdove, dabar, kai galime pasiekti piratų slėptuvę, turėtume ją užimti ir "
"su jais pribaigti. Galbūt jų teritorijoje paslėpta ir daugiau lobių."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:100
msgid "The pirates were defeated."
msgstr "Piratai buvo nugalėti."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:101
msgid ""
"Sire, we have defeated the pirates. They have hidden some gold in their last"
" bastion which is now being transferred to our headquarters."
msgstr ""
"Valdove, mes nugalėjome piratus. Savo paskutiniame bastione jie buvo paslėpę"
" šiek tiek aukso, kuris dabar gabenamas į mūsų būstinę."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:106
msgid "Pirates are regrouping"
msgstr "Piratai persigrupuoja"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:107
msgid ""
"Sire, as a result of our attacks on the pirates they have started to regroup"
" with pirates from other tribes. They could regain much of their previously "
"lost strength. Our dwindling resources can become a problem with such a "
"mighty enemy in front of us."
msgstr ""
"Valdove, po mūsų atakų piratai pradėjo vienytis su kitų genčių piratais. Jie"
" gali atgauti didžiąją dalį prarastų jėgų. Prieš mus stovint tokiam galingam"
" priešui, mūsų senkantys ištekliai gali tapti didele problema."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:112
msgid "Pirates on the run"
msgstr "Piratai bėga"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:113
msgid ""
"Sire, thanks to our successful efforts to drive out the pirates, lots of "
"them have fled and moved away in small boats. It is unknown in which "
"direction they have escaped."
msgstr ""
"Valdove, mūsų sėkmingų pastangų išvaryti piratus dėka daugelis jų paspruko "
"mažomis valtimis. Nežinoma, kuria kryptimi jie pabėgo."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:118
msgid "Ability to build shipyards"
msgstr "Galimybė statyti laivų statyklas"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:119
msgid ""
"Sire, after long study and research our wise men have finally managed to "
"decipher the strange language in Törver’s descriptions that we had found in "
"his headquarters. From now on we are able to build shipyards."
msgstr ""
"Pone, po ilgų studijų ir tyrimų mūsų išminčiai pagaliau sugebėjo iššifruoti "
"keistą kalbą Törverio aprašymuose, kuriuos radome jo būstinėje. Nuo šiol "
"galime statyti laivų statyklas."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:124
msgid "Our scout has been captured"
msgstr "Mūsų žvalgas buvo sučiuptas"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:125
msgid ""
"Sire, one of our scouts has been captured by the pirates and brought to "
"their island. He is the only person who knows the way through the swamps "
"towards Hjalmar."
msgstr ""
"Valdove, piratai sučiupo vieną iš mūsų žvalgų ir išgabeno jį į savo salą. "
"Jis yra vienintelis žmogus, žinantis kelią per pelkes link Hjalmaro."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:127
msgid ""
"According to our fishermen he is locked up in the stronghold on the island. "
"We should use the knowledge about shipbuilding that we took from Törver to "
"build ships and attack their positions."
msgstr ""
"Pasak mūsų žvejų, jis yra uždarytas salos tvirtovėje. Turėtume panaudoti "
"žinias apie laivų statybą, kurias gavome iš Törverio, kad pastatytume laivus"
" ir atakuotume jų pozicijas."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:133
msgid "Island conquered"
msgstr "Sala užimta"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:134
msgid ""
"Sire, our soldiers have conquered the island and managed to free the scout. "
"It turns out that the pirates have left a large amount of gold, beer, and "
"weapons on the island."
msgstr ""
"Valdove, mūsų kariai užėmė salą ir sugebėjo išlaisvinti žvalgą. Pasirodo, "
"piratai saloje paliko daug aukso, alaus ir ginklų."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:139
msgid "The scout returns"
msgstr "Žvalgas grįžta"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:140
msgid ""
"Sire, our scout has returned to our territory, and he has shown us the road "
"through the swamps towards Hjalmar."
msgstr ""
"Valdove, mūsų žvalgas grįžo į mūsų teritoriją ir parodė mums kelią per "
"pelkes link Hjalmaro."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:142
msgid ""
"He noticed that we can also move along the other side of the mountain, in "
"case we might fail here, but it will be much more difficult to do."
msgstr ""
"Jis pastebėjo, kad galime judėti ir kitoje kalno pusėje, jei čia nepavyktų, "
"bet tai padaryti bus daug sunkiau."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:148
msgid "The last frontier"
msgstr "Paskutinė riba"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:149
msgid ""
"Sire, we have almost defeated all armies and we are now approaching our "
"final enemy. They have been expecting us for a long time and will be "
"prepared for the heaviest battle in their lifetime."
msgstr ""
"Valdove, mes beveik nugalėjome visas kariuomenes ir dabar artėjame prie "
"paskutiniojo priešo. Jie ilgai mūsų laukė ir bus pasiruošę sunkiausiam "
"mūšiui savo gyvenime."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:151
msgid ""
"Make sure that our armies are at full strength and then act decisively."
msgstr ""
"Užtikrinkite, kad mūsų pajėgos būtų visiškai pasirengusios, ir tuomet "
"veikite ryžtingai."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:157
msgid "Victory!"
msgstr "Pergalė!"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:158
msgid "Sire, my congratulations!"
msgstr "Valdove, sveikinu!"

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:160
msgid ""
"You have completed all goals and defeated all our enemies. You have not only"
" conquered our rivalling tribes, but you have also captured the hearts of "
"your loving people."
msgstr ""
"Jūs įvykdėte visus tikslus ir nugalėjote visus mūsų priešus. Jūs ne tik "
"užkariavote konkuruojančias gentis, bet ir pavergėte savo mylinčių žmonių "
"širdis."

#: ../../../../data/maps/SP_Scenarios/Along_The_River.wmf/scripting/texts.lua:162
msgid "Your name will be remembered forever."
msgstr "Jūsų vardas bus prisimenamas amžinai."
